{
  "$schema": "https://biomejs.dev/schemas/2.3.9/schema.json",
  "root": true,
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "off"
      }
    }
  },
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/.vscode",
      "!**/.git",
      "!**/dist",
      "!**/storybook-static",
      "!**/docs",
      "!**/public",
      "!**/src/__tests__",
      "!**/src/tests",
      "!**/src/assets",
      "!**/src/styles",
      "!**/tsconfig.json",
      "!biome.json",
      "!**/biome.json",
      "!**/README.md",
      "!**/readme",
      "!**/pnpm-lock.yaml",
      "!**/.gitignore"
    ]
  },
  "linter": {
    "enabled": true,

    "rules": {
      "style": {
        "useBlockStatements": "error"
      },
      "suspicious": {
        "noArrayIndexKey": "off",
        "noAsyncPromiseExecutor": "error",
        "noCatchAssign": "error",
        "noCommentText": "error",
        "noCompareNegZero": "error",
        "noDebugger": "warn",
        "noDoubleEquals": "error",
        "noDuplicateParameters": "error",
        "noExplicitAny": "off",
        "noFunctionAssign": "error",
        "noImportAssign": "error",
        "noLabelVar": "error",
        "noShadowRestrictedNames": "error",
        "noSparseArray": "error",
        "noUnsafeNegation": "error",
        "noRedeclare": "off",
        "noTsIgnore": "off",
        "useIterableCallbackReturn": "off",
        "noPrototypeBuiltins": "off",
        "useBiomeIgnoreFolder": "off"
      },
      "complexity": {
        "noExtraBooleanCast": "error",
        "noImportantStyles": "off"
      },
      "correctness": {
        "noChildrenProp": "error",
        "noUnreachable": "error"
      },
      "performance": {
        "noDelete": "error"
      },
      "a11y": {
        "noAutofocus": "error",
        "noPositiveTabindex": "error",
        "useAltText": "error",
        "useAnchorContent": "error",
        "useButtonType": "error",
        "useKeyWithClickEvents": "warn",
        "useKeyWithMouseEvents": "off",
        "useValidAnchor": "error"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "javascript": {
    "formatter": {
      "semicolons": "asNeeded",
      "trailingCommas": "es5",
      "quoteStyle": "single"
    }
  }
}
