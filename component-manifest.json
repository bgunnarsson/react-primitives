          "default": "Disabled/Default",
          "info":    "Info/Background",
          "success": "Success/Background",
          "warning": "Warning/Background",
          "error":   "Error/Background"
        },
        "stroke": {
          "default": "Border/Default",
          "info":    "Info/Border",
          "success": "Success/Border",
          "warning": "Warning/Border",
          "error":   "Error/Border"
        },
        "children": [
          {
            "type": "shape",
            "name": "Dot",
            "shape": "ellipse",
            "width": 6,
            "height": 6,
            "fill": {
              "default": "Text/Body",
              "info":    "Info/Default",
              "success": "Success/Default",
              "warning": "Warning/Default",
              "error":   "Error/Default"
            },
            "visibleProp": "Show Dot",
            "visibleDefault": false
          },
          {
            "type": "text",
            "name": "Label",
            "text": "Badge",
            "textStyle": "Body 5",
            "color": {
              "default": "Text/Body",
              "info":    "Info/Text",
              "success": "Success/Text",
              "warning": "Warning/Text",
              "error":   "Error/Text"
            },
            "textProp": "Label"
          }
        ]
      },
      "codeConnectProps": {
        "Label": { "type": "string", "mapsTo": "children", "default": "Badge" }
      }
    },
    {
      "name": "Switch",
      "category": "Form",
      "section": "Toggles",
      "kind": "atom",
      "variantAxes": {
        "state": ["off", "on", "disabled"]
      },
      "render": {
        "layout": "horizontal",
        "width": 44,
        "height": 24,
        "padding": [3, 3],
        "radius": "Radius/Round",
        "borderWidth": "Border/0",
        "align": {
          "off":      "left",
          "on":       "right",
          "disabled": "left"
        },
        "fill": {
          "off":      "Border/Default",
          "on":       "Primary/Blue",
          "disabled": "Disabled/Default"
        },
        "opacity": { "disabled": 0.6 },
        "children": [
          {
            "type": "shape",
            "name": "Thumb",
            "shape": "ellipse",
            "width": 18,
            "height": 18,
            "fill": "Background/Default"
          }
        ]
      },
      "codeConnectProps": {
        "Disabled": { "type": "boolean", "mapsTo": "disabled", "default": false }
      }
    },
    {
      "name": "Checkbox",
      "category": "Form",
      "section": "Toggles",
      "kind": "atom",
      "variantAxes": {
        "state": ["unchecked", "checked", "disabled"]
      },
      "render": {
        "layout": "horizontal",
        "width": 18,
        "height": 18,
        "padding": [0, 0],
        "radius": "Radius/4",
        "borderWidth": "Border/2",
        "align": "center",
        "fill": {
          "unchecked": "Background/Default",
          "checked":   "Primary/Blue",
          "disabled":  "Disabled/Default"
        },
        "stroke": {
          "unchecked": "Border/Default",
          "checked":   "Primary/Blue",
          "disabled":  "Disabled/Border"
        },
        "opacity": { "disabled": 0.6 },
        "children": [
          {
            "type": "text",
            "name": "Check",
            "text": "✓",
            "textStyle": "Body 4",
            "color": {
              "unchecked": "TRANSPARENT",
              "checked":   "Text/White",
              "disabled":  "TRANSPARENT"
            },
            "visibleWhen": { "state": "checked" }
          }
        ]
      },
      "codeConnectProps": {
        "Disabled": { "type": "boolean", "mapsTo": "disabled", "default": false }
      }
    },
