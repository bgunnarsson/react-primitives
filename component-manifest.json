{
  "components": [
    {
      "name": "Button",
      "category": "Form",
      "section": "Buttons",
      "kind": "atom",
      "variantAxes": {
        "variant": ["primary", "secondary", "outline", "ghost", "destructive"],
        "size": ["sm", "md", "lg"],
        "state": ["default", "hover", "focus", "disabled"]
      },
      "render": {
        "layout": "horizontal",
        "padding": { "sm": [8, 12], "md": [10, 16], "lg": [14, 20] },
        "gap": 8,
        "radius": "Radius/6",
        "borderWidth": "Border/1",
        "align": "center",
        "fill": {
          "primary":     { "default": "Primary/Blue",   "hover": "Primary/Blue Hover", "focus": "Primary/Blue",   "disabled": "Disabled/Default" },
          "secondary":   { "default": "Background/Default", "hover": "Disabled/Default", "focus": "Background/Default", "disabled": "Disabled/Default" },
          "outline":     { "default": "TRANSPARENT",     "hover": "Disabled/Default",   "focus": "TRANSPARENT",     "disabled": "TRANSPARENT" },
          "ghost":       { "default": "TRANSPARENT",     "hover": "Disabled/Default",   "focus": "TRANSPARENT",     "disabled": "TRANSPARENT" },
          "destructive": { "default": "Error/Default",   "hover": "Error/Default",      "focus": "Error/Default",   "disabled": "Disabled/Default" }
        },
        "stroke": {
          "secondary": { "default": "Border/Default",  "hover": "Border/Default",  "focus": "Border/Default",  "disabled": "Disabled/Border" },
          "outline":   { "default": "Outline/Default", "hover": "Outline/Default", "focus": "Outline/Default", "disabled": "Disabled/Border" }
        },
        "opacity": { "disabled": 0.6 },
        "children": [
          {
            "type": "shape",
            "name": "Leading Icon",
            "shape": "ellipse",
            "width": 14,
            "height": 14,
            "fill": {
              "primary":     "Text/White",
              "secondary":   "Text/Headline",
              "outline":     "Outline/Default",
              "ghost":       "Outline/Default",
              "destructive": "Text/White"
            },
            "visibleProp": "Show Leading Icon",
            "visibleDefault": false
          },
          {
            "type": "text",
            "name": "Label",
            "text": "Button",
            "textStyle": "Button",
            "color": {
              "primary":     "Text/White",
              "secondary":   "Text/Headline",
              "outline":     "Outline/Default",
              "ghost":       "Outline/Default",
              "destructive": "Text/White"
            },
            "textProp": "Label"
          },
          {
            "type": "shape",
            "name": "Trailing Icon",
            "shape": "ellipse",
            "width": 14,
            "height": 14,
            "fill": {
              "primary":     "Text/White",
              "secondary":   "Text/Headline",
              "outline":     "Outline/Default",
              "ghost":       "Outline/Default",
              "destructive": "Text/White"
            },
            "visibleProp": "Show Trailing Icon",
            "visibleDefault": false
          }
        ]
      },
      "codeConnectProps": {
        "Label":    { "type": "string",  "mapsTo": "children", "default": "Button" },
        "Disabled": { "type": "boolean", "mapsTo": "disabled", "default": false }
      }
    },
    {
      "name": "Input",
