        "gap": 8,
        "radius": "Radius/6",
        "borderWidth": "Border/1",
        "align": "left",
        "fill": "Background/Default",
        "stroke": {
          "default":  "Border/Default",
          "focus":    "Outline/Default",
          "disabled": "Disabled/Border",
          "error":    "Error/Border"
        },
        "opacity": { "disabled": 0.7 },
        "children": [
          {
            "type": "shape",
            "name": "Leading Icon",
            "shape": "ellipse",
            "width": 14,
            "height": 14,
