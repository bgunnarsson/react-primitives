          {
            "type": "text",
            "name": "Placeholder",
            "text": "Placeholder",
            "textStyle": "Body 4",
            "color": {
              "default":  "Text/Light",
              "focus":    "Text/Headline",
              "disabled": "Disabled/Text",
              "error":    "Text/Headline"
            },
            "fillH": true,
            "textProp": "Placeholder"
          },
          {
            "type": "shape",
            "name": "Clear",
            "shape": "ellipse",
            "width": 12,
            "height": 12,
            "fill": "Text/Light",
            "visibleProp": "Show Clear Button",
            "visibleDefault": false
          }
        ]
      },
      "codeConnectProps": {
        "Placeholder": { "type": "string",  "mapsTo": "placeholder", "default": "Placeholder" },
        "Disabled":    { "type": "boolean", "mapsTo": "disabled",    "default": false }
      }
    },
    {
      "name": "Badge",
      "category": "Display",
